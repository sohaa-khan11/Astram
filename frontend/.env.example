# Frontend Environment Variables
# Copy this to .env.local for local dev or set in Vercel dashboard for production

# Backend API URL - set this to your Render backend URL
# Example: https://astram-parking-api.onrender.com/api
# Leave empty to use /api (dev proxy via vite.config.ts)
VITE_API_BASE_URL=

# MapmyIndia REST API key - enables Mappls map tiles
# If not set, the map automatically falls back to CartoDB dark tiles (no crash)
# Same value as MAPPLS_REST_API_KEY in your backend .env
VITE_MAPPLS_API_KEY=
